# LaunchDarkly (server-side SDK keys — one per environment)
LAUNCHDARKLY_SDK_KEY=sdk-your-production-key
LAUNCHDARKLY_SDK_KEY_TEST=sdk-your-test-key
LAUNCHDARKLY_SDK_KEY_SNOWFLAKE=sdk-your-snowflake-key

# OpenAI (powers the chatbot and the Togglemon card creator, via their LD AI Configs)
OPENAI_API_KEY=your-openai-api-key

# BigQuery — profile: production-bq
BIGQUERY_PROJECT_ID=your-gcp-project
BIGQUERY_METRICS_DATASET=darktrainers_metrics
BIGQUERY_METRICS_TABLE=metric_events

# Databricks — profile: test-databricks
DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_CATALOG=your_catalog
DATABRICKS_SCHEMA=darktrainers_metrics
DATABRICKS_METRICS_TABLE=metric_events

# Snowflake — profile: snowflake
SNOWFLAKE_ACCOUNT=your-account-id
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=your-password
# Or use key-pair auth instead of password:
# SNOWFLAKE_PRIVATE_KEY=path-or-pem-content
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=your-warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=darktrainers_metrics
SNOWFLAKE_METRICS_TABLE=metric_events
# SNOWFLAKE_ROLE=ACCOUNTADMIN

# Optional
DARKTRAINERS_SIMULATION_DELAY_BETWEEN_JOURNEYS=2.0
