#!/bin/sh
#
# Pre-commit secret scan (dependency-free).
# Blocks committing real .env files and content that looks like live credentials.
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass (only if you are CERTAIN it is a false positive):   git commit --no-verify
#
set -eu

fail=0

# 1) Never commit env files that may hold secrets — only .env.example is allowed.
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
for f in $staged_files; do
  case "$f" in
    .env|.env.*)
      if [ "$f" != ".env.example" ]; then
        echo "BLOCKED: refusing to commit env file (may contain secrets): $f"
        fail=1
      fi
      ;;
  esac
done

# 2) Scan newly added lines for credential-shaped tokens (skip the .env.example template).
added=$(git diff --cached -U0 --diff-filter=ACM -- . ':(exclude).env.example' \
        | grep -E '^\+' | grep -Ev '^\+\+\+' || true)

# name|regex  (high-signal patterns; values are never printed)
patterns='
anthropic_api_key|sk-ant-[A-Za-z0-9_-]{20,}
openai_api_key|sk-[A-Za-z0-9]{32,}
aws_access_key_id|AKIA[0-9A-Z]{16}
launchdarkly_server_or_mobile_key|(sdk|mob|api)-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}
github_token|gh[pousr]_[A-Za-z0-9]{20,}
google_api_key|AIza[0-9A-Za-z_-]{35}
slack_token|xox[baprs]-[A-Za-z0-9-]{10,}
private_key_block|-----BEGIN ([A-Z ]+ )?PRIVATE KEY-----
'

while IFS='|' read -r name regex; do
  [ -z "${name:-}" ] && continue
  if printf '%s\n' "$added" | grep -Eq -e "$regex"; then
    echo "BLOCKED: staged changes contain a likely secret (pattern: $name)."
    fail=1
  fi
done <<EOF
$patterns
EOF

if [ "$fail" -ne 0 ]; then
  echo ""
  echo "Commit aborted by .githooks/pre-commit secret scan."
  echo "  - Keep secrets in an untracked .env (already gitignored); commit only .env.example with placeholders."
  echo "  - Genuine false positive? Re-run with: git commit --no-verify"
  exit 1
fi

exit 0
